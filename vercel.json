{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/sample",
      "destination": "/travel-planning-studio/sample.html",
      "permanent": false
    },
    {
      "source": "/sample.html",
      "destination": "/travel-planning-studio/sample.html",
      "permanent": false
    },
    {
      "source": "/intake",
      "destination": "/travel-planning-studio/intake.html",
      "permanent": false
    },
    {
      "source": "/intake.html",
      "destination": "/travel-planning-studio/intake.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
